# ==========================================
# Environment Variables for Vercel Deployment
# ==========================================
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to version control

# ==========================================
# NextAuth Configuration
# ==========================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secure-secret-here"

# Production URL (update after deployment)
# For local development: http://localhost:3000
# For Vercel: https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# Email Configuration (Optional)
# ==========================================
# Configure SMTP for sending booking confirmation emails
# You can use: Mailtrap, SendGrid, Gmail, Resend, etc.

EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your_email_user"
EMAIL_SERVER_PASSWORD="your_email_password"
EMAIL_FROM="noreply@your-domain.com"

# Alternative: Use Resend (recommended for Vercel)
# RESEND_API_KEY="re_xxxxxxxxxxxxx"

# ==========================================
# Demo Mode Configuration
# ==========================================
# This project runs in demo mode with mock data
# No database or backend API required

# Admin Demo Credentials:
# Email: admin@car-rental.com
# Password: admin123

# ==========================================
# Important Notes for Vercel Deployment:
# ==========================================
# 1. Add NEXTAUTH_SECRET and NEXTAUTH_URL in Vercel Environment Variables
# 2. Generate a secure NEXTAUTH_SECRET using: openssl rand -base64 32
# 3. Update NEXTAUTH_URL to your Vercel deployment URL after first deploy
# 4. File uploads are stored in /public/uploads (note: Vercel serverless functions have limitations)
# 5. For production file uploads, consider using cloud storage (AWS S3, Cloudinary, Vercel Blob)
